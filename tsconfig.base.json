{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    // "baseUrl":".",
    // "paths": {
    //   "@clarte/shared": [
    //     "packages/shared/src/index.ts"
    //   ]
    // },
    "target": "ES2022",
    "customConditions": ["@clarte/source"]
  }
}
